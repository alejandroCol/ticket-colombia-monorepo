rules_version = '2';

// Firebase Storage Security Rules for Ticket Colombia
service firebase.storage {
  match /b/{bucket}/o {

    // Mismo criterio que el panel admin (auth.ts): ADMIN, admin, SUPER_ADMIN
    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function isPanelAdmin() {
      return request.auth != null &&
        firestore.exists(userDocPath()) &&
        (
          firestore.get(userDocPath()).data.role == 'ADMIN' ||
          firestore.get(userDocPath()).data.role == 'admin' ||
          firestore.get(userDocPath()).data.role == 'SUPER_ADMIN'
        );
    }

    function isSuperAdminStorage() {
      return request.auth != null &&
        firestore.exists(userDocPath()) &&
        firestore.get(userDocPath()).data.role == 'SUPER_ADMIN';
    }

    // Event cover images - anyone can read, only authenticated admins can write
    match /event-covers/{fileName} {
      allow read: if true;
      allow write: if isPanelAdmin();
    }

    // Home page banners - anyone can read, solo super admin escribe (alineado con panel Banners)
    match /banners/{fileName} {
      allow read: if true;
      allow write: if isSuperAdminStorage();
    }

    // Event ticket boleto (background) images - anyone can read, only admins can write
    match /event-boleto/{fileName} {
      allow read: if true;
      allow write: if isPanelAdmin();
    }

    // Mapas de localidades generados en el admin (PNG)
    match /venue-maps/{fileName} {
      allow read: if true;
      allow write: if isPanelAdmin();
    }

    // User profile images - users can write their own, anyone can read
    match /profile-images/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Ticket QR codes - only the ticket owner or admins can read
    match /ticket-qr/{ticketId}/{fileName} {
      allow read: if request.auth != null && (
        firestore.get(/databases/(default)/documents/tickets/$(ticketId)).data.userId == request.auth.uid ||
        isPanelAdmin()
      );

      allow write: if false;
    }

    // Default deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
