rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function isAdminRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (userRole() == 'ADMIN' || userRole() == 'admin' || userRole() == 'SUPER_ADMIN');
    }

    function isPartnerUser() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userRole() == 'PARTNER';
    }

    function partnerGrantDoc(kind, eventId) {
      return /databases/$(database)/documents/event_partner_grants/$(request.auth.uid + '_' + kind + '_' + eventId);
    }

    function partnerPerm(kind, eventId, perm) {
      return exists(partnerGrantDoc(kind, eventId)) && get(partnerGrantDoc(kind, eventId)).data.permissions[perm] == true;
    }

    function partnerCanReadTicketsEvent(eventId) {
      return isPartnerUser() && (
        partnerPerm('evt', eventId, 'read_tickets') ||
        partnerPerm('rec', eventId, 'read_tickets') ||
        partnerPerm('evt', eventId, 'scan_validate') ||
        partnerPerm('rec', eventId, 'scan_validate')
      );
    }

    function partnerCanValidateScan(eventId) {
      return isPartnerUser() && (
        partnerPerm('evt', eventId, 'scan_validate') ||
        partnerPerm('rec', eventId, 'scan_validate')
      );
    }

    function partnerCanViewStatsEvent(eventId) {
      return isPartnerUser() && (
        partnerPerm('evt', eventId, 'view_stats') ||
        partnerPerm('rec', eventId, 'view_stats')
      );
    }

    function isPanelAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
        );
    }
    // Events collection - publicly readable, authenticated users can write
    match /events/{eventId} {
      allow read: if true; // Allow anyone to read event data
      allow create, update, delete: if request.auth != null; // Only authenticated users can write
    }
    
    // Recurring events collection - publicly readable, authenticated users can write
    match /recurring_events/{eventId} {
      allow read: if true; // Allow anyone to read recurring event data
      allow create, update, delete: if request.auth != null; // Only authenticated users can write
    }
    
    // Users: perfil propio; lectura para admins; solo SUPER_ADMIN puede crear/editar documentos de otros usuarios
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN';
    }
    
    // Tarifa al comprador por organizador (solo super admin escribe; lectura pública para checkout)
    match /organizer_buyer_fees/{organizerId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN';
    }

    // Configurations collection - publicly readable, only admins can write
    match /configurations/{configId} {
      allow read: if true; // Allow anyone to read configuration data (landing, app)
      allow create, update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
      allow delete: if false;
    }
    
    // Permisos de partner por evento (solo super admin escribe; el partner lee lo suyo)
    match /event_partner_grants/{grantId} {
      allow read: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN';
    }

    // Tickets collection - users can read their own tickets, admins can read/update all
    match /tickets/{ticketId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdminRole() ||
        partnerCanReadTicketsEvent(resource.data.eventId)
      );

      allow update: if request.auth != null && (
        isAdminRole() ||
        partnerCanValidateScan(resource.data.eventId)
      );

      allow create, delete: if false;
    }
    
    // Expenses collection - admin full; partner solo lectura con view_stats en ese evento
    match /expenses/{expenseId} {
      allow read: if request.auth != null && (
        isAdminRole() ||
        partnerCanViewStatsEvent(resource.data.eventId)
      );
      allow write: if request.auth != null && isAdminRole();
    }
    
    // Venues collection - only admin users can read/write
    match /venues/{venueId} {
      // Admin y partner (edición de eventos puede usar venues)
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'PARTNER'
      );
      
      // Only authenticated admin users can create, update, delete venues
      allow create, update, delete: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
      );
    }

    // Reservas de cupo (solo Cloud Functions / Admin SDK)
    match /ticket_reservations/{reservationId} {
      allow read, write: if false;
    }

    // Plantillas de mapa de localidades (por organizador)
    match /venue_map_templates/{templateId} {
      allow read: if request.auth != null && (
        resource.data.organizer_id == request.auth.uid ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN'
        )
      );
      allow create: if request.auth != null &&
        isPanelAdmin() &&
        request.resource.data.organizer_id == request.auth.uid;
      allow update, delete: if request.auth != null &&
        isPanelAdmin() &&
        resource.data.organizer_id == request.auth.uid;
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 